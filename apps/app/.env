# Default local build environment variables for the Doenet app.
# This file is intentionally committed — all VITE_ vars are public.
# Use .env.local for machine-specific overrides.
VITE_DISCOURSE_URL=http://localhost:3031
# Media CDN base — must match the API's MEDIA_CDN_BASE_URL for this environment.
# Passed to the DoenetML viewer as doenetMediaUrl to resolve doenet:<key> images.
VITE_MEDIA_CDN_BASE_URL=http://localhost:9090/doenet-media